{
  "name": "react-native-thermal-printer-driver",
  "version": "0.1.1",
  "description": "React Native thermal printer driver for ESC/POS printers over Bluetooth Classic, BLE, and TCP. TurboModule with full New Architecture support.",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "source": "./src/index.ts",
  "react-native": "./src/index.ts",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/src/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json",
    "./app.plugin.js": "./app.plugin.js",
    "./react-native.config.js": "./react-native.config.js"
  },
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "app.plugin.js",
    "react-native.config.js",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "example": "yarn workspace react-native-thermal-printer-driver-example",
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "test": "jest"
  },
  "keywords": [
    "react-native",
    "thermal-printer",
    "escpos",
    "bluetooth",
    "ble",
    "pos",
    "receipt",
    "turbomodule",
    "new-architecture"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bloodf/expo-thermal-printer-driver.git"
  },
  "author": "Heitor Ramon <heitor@bloodf.dev> (https://github.com/bloodf)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/bloodf/expo-thermal-printer-driver/issues"
  },
  "homepage": "https://github.com/bloodf/expo-thermal-printer-driver#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@react-native/babel-preset": "0.83.0",
    "@react-native/eslint-config": "0.83.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.12",
    "babel-jest": "^30.3.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.3.0",
    "prettier": "^2.8.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.40.18",
    "ts-jest": "^29.4.6",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {
    "expo": ">=54.0.0",
    "react": "*",
    "react-native": ">=0.76.0"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": true
    }
  },
  "workspaces": [
    "example"
  ],
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNThermalPrinterDriverSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "ios": {
      "modulesProvider": {
        "ThermalPrinterDriver": "ThermalPrinterDriver"
      }
    },
    "android": {
      "javaPackageName": "com.thermalprinterdriver"
    }
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "kotlin-objc",
    "tools": [
      "eslint"
    ],
    "version": "0.57.2"
  }
}
